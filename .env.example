# Copy to .env.local and adjust as needed. All integrations degrade gracefully
# to deterministic mocks when their variable is unset, so the app builds, tests
# and runs fully offline. Set these to activate the real integrations.

# Render the UN Comtrade trade-flow panel on the screening page.
# "true" enables it; anything else hides it.
NEXT_PUBLIC_COMTRADE_ENABLED=false

# ── Anthropic (Claude) ───────────────────────────────────────────────────────
# Powers AI enrichment (adverse-media sentiment/category, screening reasoning).
# Without it those helpers fall back to deterministic logic. Model: claude-opus-4-8.
ANTHROPIC_API_KEY=

# ── Asana case sync (/api/asana/sync) ────────────────────────────────────────
# Personal Access Token. Without it, the route returns a deterministic mock task.
ASANA_ACCESS_TOKEN=
# Optional: attach created tasks to a project, or fall back to a workspace.
ASANA_PROJECT_ID=
ASANA_WORKSPACE_ID=

# ── Free adverse media (Google News RSS) ─────────────────────────────────────
# Pulls live free Google-News headlines for the Adverse Media module. No API key
# required. LIVE + WORLDWIDE by default everywhere (dev + prod): every major
# Google-News locale edition (US, UK, Türkiye, Arabic, Russia, China, …) is
# searched in parallel and merged, so coverage is global and multi-language.
# Live results are never replaced with mock data. Set "false" to force seed-only.
ADVERSE_MEDIA_LIVE=

# ── Free / open sanctions + PEP lists (OpenSanctions, bundled at build) ───────
# Sanctions + PEP screening needs NO API key. At build time
# (scripts/build-sanctions-index.mjs) the free, openly-licensed OpenSanctions
# consolidated lists (OFAC, UN, EU, UK, Interpol) and PEP dataset are compiled
# into a compact index that ships in the deploy and is matched in-process at
# runtime — no key, no per-request network. The build is resilient: if the data
# can't be fetched it writes an empty index and the app reports "not screened".

# Set "1" to skip the build-time download (CI uses this for fast, hermetic builds).
SKIP_SANCTIONS_INDEX=
# Base URL for the free OpenSanctions data exports (override for a mirror).
# OPENSANCTIONS_DATA_BASE=https://data.opensanctions.org/datasets/latest
# Cap on indexed entities (bounds bundle size / build memory).
# SANCTIONS_INDEX_MAX=1500000

# Optional REMOTE fallback, used ONLY when no local index is bundled. Point at a
# self-hosted yente for free, unlimited matching. https://www.opensanctions.org/docs/yente/
SANCTIONS_LIVE=
# OPENSANCTIONS_API_URL=http://localhost:8000
# OPENSANCTIONS_INDEX_URL=http://localhost:8000/catalog

# ── Audit-chain signing (/api/audit/sign) ────────────────────────────────────
# Secret key for the HMAC-SHA256 audit signature + verification. Set a strong,
# private value in production so audit signatures can't be forged. Without it the
# route falls back to an insecure, clearly-labelled dev key (demo only — do NOT
# rely on its signatures for tamper evidence).
AUDIT_SIGNING_SECRET=

# ── RBAC posture (src/lib/auth/rbac.ts) ──────────────────────────────────────
# Privileged actions (MLRO sign-off, audit export) are gated by role. Identity
# is taken from request context (x-hawkeye-actor / x-hawkeye-role headers). By
# default an anonymous caller resolves to the least-privileged "analyst" role so
# the offline demo works. Set to "1" for a production posture: an anonymous
# caller is rejected (401) instead of defaulting.
HAWKEYE_RBAC_STRICT=
