# Copy to .env.local and adjust as needed. All integrations degrade gracefully
# to deterministic mocks when their variable is unset, so the app builds, tests
# and runs fully offline. Set these to activate the real integrations.

# Render the UN Comtrade trade-flow panel on the screening page.
# "true" enables it; anything else hides it.
NEXT_PUBLIC_COMTRADE_ENABLED=false

# ── Anthropic (Claude) ───────────────────────────────────────────────────────
# Powers AI enrichment (adverse-media sentiment/category, screening reasoning).
# Without it those helpers fall back to deterministic logic. Model: claude-opus-4-8.
ANTHROPIC_API_KEY=

# ── Asana case sync (/api/asana/sync) ────────────────────────────────────────
# Personal Access Token. Without it, the route returns a deterministic mock task.
ASANA_ACCESS_TOKEN=
# Optional: attach created tasks to a project, or fall back to a workspace.
ASANA_PROJECT_ID=
ASANA_WORKSPACE_ID=

# ── Free adverse media (Google News RSS) ─────────────────────────────────────
# "true" pulls live free Google-News headlines for the Adverse Media module.
# No API key required. Off by default so tests/CI stay deterministic.
ADVERSE_MEDIA_LIVE=false

# ── Free / open sanctions lists (OpenSanctions) ──────────────────────────────
# "true" reads live list metadata + name matches from the free OpenSanctions
# data index/API. No API key required. Off by default for deterministic tests.
SANCTIONS_LIVE=false
